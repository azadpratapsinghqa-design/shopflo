{
  "name": "fakestoreapi-tests",
  "version": "1.0.0",
  "description": "API test suite for FakeStoreAPI Cart CRUD",
  "scripts": {
    "test": "jest --runInBand",
    "test:parallel": "jest --maxWorkers=4",
    "test:verbose": "jest --verbose",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.2",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-results",
          "outputName": "results.xml"
        }
      ]
    ],
    "globalSetup": "./tests/globalSetup.js",
    "testTimeout": 15000
  }
}
